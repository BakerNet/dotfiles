{
  "$schema" : "https:\/\/schema.linearmouse.app\/0.11.0-beta.5",
  "schemes" : [
    {
      "buttons" : {
        "autoScroll" : {
          "enabled" : true,
          "mode" : [
            "toggle",
            "hold"
          ],
          "preserveNativeMiddleClick" : true,
          "speed" : 2.5,
          "trigger" : {
            "button" : 2
          }
        }
      },
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0xc547",
          "productName" : "USB Receiver",
          "vendorID" : "0x46d"
        }
      },
      "scrolling" : {
        "reverse" : {
          "vertical" : true
        }
      }
    }
  ]
}